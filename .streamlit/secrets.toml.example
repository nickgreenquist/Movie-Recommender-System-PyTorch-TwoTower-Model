# Streamlit secrets for the conversational "Ask" tab.
#
# Copy this file to .streamlit/secrets.toml (which is gitignored — never commit a real key) and
# paste your Anthropic API key below. Get one at https://console.anthropic.com/ .
#
# The key powers ONLY the natural-language "Ask" tab (intent parsing via Claude Haiku). The rest of
# the app — the manual Recommend tab, Examples, Similar, Genres, Genome, Map — needs no key.
#
# On Streamlit Community Cloud, set this in the app's Settings → Secrets dashboard instead of a file.
# A bare ANTHROPIC_API_KEY environment variable also works for local runs.

ANTHROPIC_API_KEY = "sk-ant-..."
